PORT=3001
NODE_ENV=development

# Swagger: GET /docs or /api/docs (UI, CDN), GET /openapi.json (OpenAPI spec)

# Comma-separated browser origins allowed by CORS (your Vercel frontend URL(s))
CORS_ORIGIN=http://localhost:5173

# Optional: single production frontend URL (merged into CORS allow list)
# FRONTEND_URL=https://burger-shop-frontend.vercel.app

# Set on the API project so Preview frontends (*.vercel.app) can call the API
# CORS_ALLOW_VERCEL_PREVIEWS=1

# How many reverse proxies sit in front of this API (local dev; Vercel sets trust proxy automatically)
TRUST_PROXY_HOPS=1

# --- Logging / Cloudflare ---
# If set, access logs ALWAYS print this IP (your origin’s stdout/log shipper only).
# STATIC_LOG_IP=203.0.113.10

# When STATIC_LOG_IP is unset and the API sits behind Cloudflare (orange cloud), set to 1 so logs
# use CF-Connecting-IP (visitor IP as Cloudflare sees it) instead of a Cloudflare colo IP on req.ip.
TRUST_CLOUDFLARE=0
