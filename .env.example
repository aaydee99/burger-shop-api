PORT=3001
NODE_ENV=development

# Swagger: GET /docs or /api/docs (UI, CDN), GET /openapi.json (OpenAPI spec)

# Comma-separated allowed browser origins (merged with CORS_ORIGINS and FRONTEND_URL).
# CORS_ORIGIN=https://burger-shop-frontend.vercel.app,https://www.example.com

# Same as CORS_ORIGIN but a second list (optional); both are merged.
# CORS_ORIGINS=

# Single frontend base URL (merged into the allow list).
# FRONTEND_URL=https://burger-shop-frontend.vercel.app

# Allow any *.vercel.app origin (default on). Set to 0/false for explicit list + localhost only.
# CORS_ALLOW_VERCEL_PREVIEWS=0

# Allow any *.onrender.com origin (default on). Set to 0/false to disable.
# CORS_ALLOW_RENDER_HOSTS=0

# Log blocked origins in production (default off).
# CORS_DEBUG=1

# How many reverse proxies sit in front of this API (local dev; Vercel sets trust proxy automatically)
TRUST_PROXY_HOPS=1

# --- Logging / Cloudflare ---
# If set, access logs ALWAYS print this IP (your origin’s stdout/log shipper only).
# STATIC_LOG_IP=203.0.113.10

# When STATIC_LOG_IP is unset and the API sits behind Cloudflare (orange cloud), set to 1 so logs
# use CF-Connecting-IP (visitor IP as Cloudflare sees it) instead of a Cloudflare colo IP on req.ip.
TRUST_CLOUDFLARE=0

